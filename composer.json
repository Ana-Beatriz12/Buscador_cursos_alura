{
    "name": "ana-beatriz12/buscador-cursos",
    "description": "Projeto que busca os cursos no site da alura",
    "type": "library",
    "require": {
        "guzzlehttp/guzzle": "^7.9",
       "symfony/dom-crawler":"^6.0",
        "symfony/css-selector": "^6.0"
    },
    "autoload": {
        "files": ["src/functions.php"],
        "psr-4": {
